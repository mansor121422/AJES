# Environment (contains secrets - do not commit)
.env

# CodeIgniter
writable/cache/*
writable/logs/*
writable/session/*
writable/uploads/*
!writable/cache/index.html
!writable/logs/index.html
!writable/session/index.html
!writable/uploads/index.html

# Database dumps (Lab 4 scripts — do not commit backups)
writable/backups/*.sql
writable/backups/*.sql.gz
!writable/backups/index.html
