# Copy to htdocs/.env on InfinityFree (rename from env.infinityfree.example)

CI_ENVIRONMENT = production

app.baseURL = https://ajescrier.infinityfreeapp.com/
app.extraHosts = ajescrier.infinityfreeapp.com

# Required on InfinityFree so menu links use index.php/chat (not bare /chat)
app.indexPage = index.php
FORCE_INDEX_PAGE = true

# AJESCHAT Android (local.properties) — use index.php in base URL if /api/login returns 404:
# ajes.baseUrl=https://ajescrier.infinityfreeapp.com/index.php/
# Or upload api/.htaccess from the project and use:
# ajes.baseUrl=https://ajescrier.infinityfreeapp.com/

database.default.hostname = sqlXXX.infinityfree.com
database.default.database = if0_XXXXXX_ajesdb
database.default.username = if0_XXXXXX
database.default.password = YOUR_MYSQL_PASSWORD
database.default.DBDriver = MySQLi

ENCRYPTION_KEY = hex2bin:paste_same_key_from_local_env
